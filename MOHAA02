def GENERATE_SMART_PASSWORDS(full_name):
    """
    خوارزمية توليد الباسووردات الذكية - قلب الأداة النابض.
    تحول اسم الشخص إلى قائمة باسووردات محتملة جداً.
    """
    passwords = []
    if not full_name: return ["123456", "12345678"]
    
    # تنظيف الاسم وتحويله لحروف صغيرة (Lowercase)
    name_clean = full_name.lower().strip()
    first_name = name_clean.split(' ')[0]
    
    # قائمة الباسووردات الأساسية
    passwords.append(name_clean) # الاسم الكامل
    passwords.append(name_clean.replace(" ", "")) # الاسم بدون فراغات
    
    # إذا كان الاسم يتكون من أكثر من مقطع
    if len(name_clean.split(' ')) > 1:
        last_name = name_clean.split(' ')[1]
        passwords.append(first_name + last_name)
        passwords.append(first_name + " " + last_name)
        passwords.append(last_name + "123")
        passwords.append(last_name + "1234")

    # إضافات شائعة تعتمد على الاسم الأول
    if len(first_name) >= 3:
        passwords.append(first_name + "123")
        passwords.append(first_name + "1234")
        passwords.append(first_name + "12345")
        passwords.append(first_name + "123456")
        passwords.append(first_name + "2024")
        passwords.append(first_name + "2025")
        passwords.append(first_name + "2026")
        passwords.append(first_name + "0000")
        passwords.append(first_name + "1122")

    # باسووردات عامة قوية في الجزائر والوطن العربي
    passwords.extend(["123456", "12345678", "123456789", "102030", "789456", "password"])
    
    # إزالة التكرار لضمان السرعة
    return list(set(passwords))
