def BYPASS_STRATEGY_MANAGER(response_data):
    """
    محرك اتخاذ القرار: يحلل رد فعل فيسبوك ويغير الخطة فوراً يا موحا.
    """
    error_code = str(response_data.get("error_code", ""))
    error_msg = response_data.get("error_msg", "").lower()

    # 1. إذا اكتشف فيسبوك ضغطاً كبيراً (Rate Limit)
    if "calls_limit" in error_msg or "368" in error_code:
        print(f"\n{R} [!] FB DETECTED HIGH TRAFFIC! SWITCHING STRATEGY...")
        # زيادة وقت الانتظار وتغيير جميع البروكسيات
        time.sleep(30)
        REFRESH_PROXIES()
        return "CHANGE_PROXY"

    # 2. إذا كان البروكسي محظوراً (Proxy Blocked)
    elif "405" in error_code or "access denied" in error_msg:
        return "SKIP_PROXY"

    # 3. إذا كان الجهاز (User-Agent) قديم أو مكشوف
    elif "invalid user agent" in error_msg:
        LOAD_UA_DATABASE() # تحديث قائمة الـ UA
        return "CHANGE_UA"

    return "CONTINUE"

def DYNAMIC_API_SWITCHER(attempt_num):
    """
    التنقل بين روابط فيسبوك المختلفة لتمويه أنظمة المراقبة.
    """
    # قائمة بروابط API مختلفة (كلها تؤدي للغرض لكن بمسارات مختلفة)
    api_endpoints = [
        "https://b-api.facebook.com/method/auth.login",
        "https://graph.facebook.com/auth/login",
        "https://m.facebook.com/login/device-based/login/async/"
    ]
    # تغيير الرابط كل 100 محاولة لكسر الرصد
    return api_endpoints[attempt_num % len(api_endpoints)]

