# [6] نظام كشف الربط بإنستغرام (Instagram Link Detector)
class IGDetector:
    def is_linked(self, email):
        """فحص ربط الإنستغرام عبر الـ API العام"""
        url = f"https://i.instagram.com/api/v1/users/lookup/"
        payload = {"q": email}
        head = {"User-Agent": "Instagram 255.0.0.1.1"}
        try:
            res = requests.post(url, data=payload, headers=head).text
            if '"user":true' in res or "email_sent" in res:
                return True
            return False
        except: return False

