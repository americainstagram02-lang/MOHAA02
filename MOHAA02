def ID_FILTER_ENGINE(raw_list):
    """
    عقل التصفية: يقوم بحذف التكرار، إصلاح الأخطاء، وترتيب الآيديات.
    يضمن أن الأداة لا تفحص نفس الشخص مرتين يا موحا.
    """
    banner()
    print(f"{Y} [!] INITIALIZING SMART FILTER SYSTEM...")
    
    clean_list = []
    seen_ids = set() # استخدام Set لسرعة البحث البرمجية (O(1))
    duplicates = 0
    errors = 0
    
    for line in raw_list:
        line = line.strip()
        if not line: continue
        
        try:
            # التحقق من الصيغة (ID|NAME) أو (ID) فقط
            if "|" in line:
                uid = line.split("|")[0]
            else:
                uid = line
            
            # التأكد من أن الآيدي رقمي وليس نصاً تالفاً
            if uid.isdigit():
                if uid not in seen_ids:
                    clean_list.append(line)
                    seen_ids.add(uid)
                else:
                    duplicates += 1
            else:
                errors += 1
        except:
            errors += 1
            
    print(f"{G} [✓] FILTERING COMPLETE:")
    print(f"{G} [>] UNIQUE IDs FOUND : {W}{len(clean_list)}")
    print(f"{R} [>] DUPLICATES REMOVED: {W}{duplicates}")
    print(f"{R} [>] INVALID FORMATS  : {W}{errors}")
    time.sleep(2)
    
    return clean_list

