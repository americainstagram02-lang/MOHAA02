def get_fb_token(cookie):
    """
    دالة تقنية لاستخراج توكن Business Manager (EAAG) لضمان سحب سريع.
    """
    try:
        headers = {
            "authority": "business.facebook.com",
            "cache-control": "max-age=0",
            "accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8",
            "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "cookie": cookie
        }
        # الدخول لصفحة بزنس فيسبوك لاستخراج التوكن المخفي
        res = requests.get("https://business.facebook.com/business_locations", headers=headers).text
        token = re.search('(\["EAAG\w+)', res).group(1).replace('["', '')
        return token
    except Exception as e:
        return None

def execute_scraping(target, token, cookie, save_file):
    """
    المحرك الفعلي لجمع الآيديات وحفظها بصيغة ID|NAME.
    """
    banner()
    print(f"{Y} [*] SCRAPING STARTED FOR TARGET: {C}{target}")
    print(f"{W} ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    
    try:
        # استخدام API الجراف لجمع قائمة الأصدقاء
        url = f"https://graph.facebook.com/{target}/friends?access_token={token}"
        response = requests.get(url, cookies={'cookie': cookie}).json()
        
        if 'data' in response:
            count = 0
            with open(save_file, "a", encoding="utf-8") as f:
                for user in response['data']:
                    # حفظ بصيغة (ID|NAME) لتكون جاهزة للأمر الثالث (File Crack)
                    f.write(f"{user['id']}|{user['name']}\n")
                    count += 1
