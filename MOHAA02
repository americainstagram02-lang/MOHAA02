import time

# متغيرات لحساب السرعة
start_time = time.time()

def GET_SCAN_SPEED():
    """
    حساب عدد الحسابات المفحوصة في الدقيقة الواحدة.
    """
    global start_time, loop
    elapsed_time = time.time() - start_time
    if elapsed_time <= 0: return 0
    # حساب السرعة: (عدد الدورات / الثواني) * 60 ثانية
    speed = (loop / elapsed_time) * 60
    return round(speed, 2)

def DRAW_PROGRESS_BAR(current, total, bar_length=20):
    """
    رسم شريط تقدم (Progress Bar) احترافي يتغير لونه مع التقدم.
    """
    fraction = current / total if total > 0 else 0
    arrow = int(fraction * bar_length - 1) * '=' + '>'
    padding = int(bar_length - len(arrow)) * ' '
    
    # تغيير لون الشريط بناءً على الإنجاز
    if fraction < 0.5: color = R # أحمر في البداية
    elif fraction < 0.8: color = Y # أصفر في المنتصف
    else: color = G # أخضر عند الاقتراب من النهاية
    
    return f"[{color}{arrow}{padding}{W}] {int(fraction*100)}%"

