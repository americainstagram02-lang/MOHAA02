def EXTRACT_TOKEN(COOKIE):
    print(YELLOW + " [*] EXTRACTING TOKEN FROM COOKIE...")
    HEADERS = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Referer': 'https://www.instagram.com/',
        'Host': 'www.facebook.com',
        'Origin': 'https://www.instagram.com',
        'Accept': '*/*',
        'Connection': 'keep-alive',
    }
    try:
        URL = "https://www.facebook.com/x/oauth/status?client_id=124024574287414&wants_cookie_data=true&origin=1"
        RESP = requests.get(URL, cookies={'cookie': COOKIE}, headers=HEADERS)
        if 'access_token' in RESP.text:
            MATCH = re.search('"access_token":"(.*?)"', RESP.text)
            if MATCH:
                return MATCH.group(1)
        return None
    except Exception as E:
        print(RED + f" [!] TOKEN EXTRACTION ERROR: {str(E)}")
        return None

