def CALCULATE_SUCCESS_RATE(total_scanned, ok_count):
    """
    تحليل نسبة النجاح لإعطائك فكرة عن جودة قائمة الآيديات التي تسحبها.
    """
    if total_scanned == 0: return 0.0
    rate = (ok_count / total_scanned) * 100
    return round(rate, 2)

