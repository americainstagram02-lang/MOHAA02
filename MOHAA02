def EXTRACT_MOHA_COOKIES(session_cookies):
    """
    تحويل ملفات تعريف الارتباط من صيغة القاموس إلى صيغة النص (String) 
    التي تقبلها الإضافات مثل 'Cookie Editor'.
    """
    try:
        # ترتيب الكوكيز بالشكل الذي يفضله فيسبوك لفتح الحساب فوراً
        c_user = session_cookies.get('c_user')
        xs = session_cookies.get('xs')
        fr = session_cookies.get('fr')
        datr = session_cookies.get('datr')
        
        if c_user and xs:
            cookie_string = f"c_user={c_user};xs={xs};fr={fr};datr={datr};"
            return cookie_string
        return "NO_COOKIES_EXTRACTED"
    except:
        return "ERROR_IN_EXTRACTION"

