# [21] نظام سحب معلومات الفيس المربوط (FB Info Extractor)
class FBInfoScanner:
    def get_fb_details(self, email):
        """محاولة سحب اسم الحساب المربوط وعدد أصدقائه إن أمكن"""
        try:
            # استخدام واجهة عرض الملف الشخصي العامة
            url = f"https://mbasic.facebook.com/search/top/?q={email}"
            res = requests.get(url, headers={'User-Agent': 'Mozilla/5.0'}).text
            if "Friends" in res:
                friends = re.search(r'(\d+)\sFriends', res).group(1)
                return f"Friends: {friends}"
            return "Active Account"
        except: return "No Details"

# [22] نظام استخراج يوزر إنستغرام (IG Username Scraper)
class IGInfoScanner:
    def get_username(self, email):
        """استخراج يوزر الحساب المربوط بالمتاح لسهولة البحث عنه"""
        try:
            url = f"https://www.instagram.com/api/v1/users/lookup_email/"
            payload = {"email": email}
            res = requests.post(url, data=payload).json()
            if res.get("user"):
                return f"User: @{res['user']['username']}"
            return "Linked Account"
        except: return "Linked"

