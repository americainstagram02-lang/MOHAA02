def ENCRYPT_RESULT_DATA(PLAIN_TEXT):
    # Basic obfuscation for saved data to prevent easy reading by scanners
    KEY = 0x55
    ENCRYPTED = "".join(chr(ord(C) ^ KEY) for C in PLAIN_TEXT)
    return base64.b64encode(ENCRYPTED.encode()).decode()

def DECRYPT_RESULT_DATA(ENCRYPTED_TEXT):
    # Decodes the obfuscated data back to human-readable format
    KEY = 0x55
    DECODED_BASE64 = base64.b64decode(ENCRYPTED_TEXT).decode()
    DECRYPTED = "".join(chr(ord(C) ^ KEY) for C in DECODED_BASE64)
    return DECRYPTED

