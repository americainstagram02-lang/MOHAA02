# [3] نظام فحص متاح الهوتميل (Hotmail Availability Checker)
class HotmailChecker:
    def check_avail(self, email):
        """فحص إذا كان إيميل الهوتميل متاح للتسجيل (غير موجود)"""
        url = "https://login.live.com/api/v1/instances/1/realms/user/check"
        params = {"uaid": str(uuid.uuid4()), "username": email}
        try:
            res = requests.get(url, params=params).text
            if '"isAvailable":true' in res or '"Exists":false' in res:
                return True
            return False
        except: return False

# [4] نظام فحص متاح الجميل (Gmail Availability Checker)
class GmailChecker:
    def check_avail(self, email):
        """فحص متاح الجميل عبر واجهة جوجل الرسمية"""
        url = "https://accounts.google.com/InputValidator?resource=AccountAddition"
        data = {"input01": {"Input": "GmailAddress", "GmailAddress": email.split('@')[0]}}
        try:
            res = requests.post(url, json=data).text
            if '"Valid":true' in res: return True
            return False
        except: return False

# [5] نظام كشف الربط بفيسبوك (Facebook Link Detector)
class FBDetector:
