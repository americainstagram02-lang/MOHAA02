        # 2. بدء المحرك
        global_error_handler()
        
        # 3. التقفيل النهائي عند الانتهاء
        finalize_files()
        
    except Exception as final_err:
        print(f"{Z} CRITICAL SYSTEM FAILURE: {final_err}")

