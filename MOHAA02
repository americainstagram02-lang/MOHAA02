def TRANSLITERATE_ARABIC(name):
    """
    إذا كان اسم الضحية بالعربية، نقوم بتحويله تقريبياً للفرنسية/الإنجليزية 
    لأن أغلب الباسووردات تُكتب بحروف لاتينية.
    """
    # مثال بسيط: محمد -> mohamed
    # هذه الدالة تجعل الأداة تفهم الأسماء العربية وتولد لها باسووردات فرانكو
    ar_to_en = {
        'محمد': 'mohamed', 'أحمد': 'ahmed', 'علي': 'ali',
        'حمزة': 'hamza', 'عبد': 'abdo', 'ياسين': 'yassine'
    }
    for ar, en in ar_to_en.items():
        if ar in name:
            return en
    return name
