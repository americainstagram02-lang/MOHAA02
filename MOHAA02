def ALGERIAN_PASS_GENERATOR(full_name, uid):
    """
    توليد باسووردات ذكية تعتمد على الثقافة المحلية والأنماط الشائعة في الجزائر.
    """
    p_list = []
    if not full_name: return ["123456", "12345678", "102030"]
    
    # تنظيف الاسم وتجهيز المقاطع
    name_parts = full_name.lower().split(' ')
    fn = name_parts[0] # الاسم الأول
    ln = name_parts[1] if len(name_parts) > 1 else fn # اللقب
    
    # 1. نمط أرقام الهواتف (الجزائر) - محاكاة شائعة جداً
    # توليد باسووردات تشبه أرقام موبيليس، جيزي، وأوريدو باستخدام الآيدي أو الاسم
    p_list.append("05" + uid[-8:]) # محاكاة رقم هاتف بالآيدي
    p_list.append("06" + uid[-8:])
    p_list.append("07" + uid[-8:])
    
    # 2. نمط الأسماء مع أرقام الولايات (02, 16, 31...)
    algeria_codes = ["02", "16", "31", "19", "25", "06", "13"] # Chlef, Algiers, Oran, etc.
    for code in algeria_codes:
        p_list.append(fn + code)
        p_list.append(fn + "dz" + code)

    # 3. نمط الأندية والرياضة (شائع جداً في الجزائر)
    clubs = ["mca", "usma", "jsk", "crb", "ess"]
    for club in clubs:
        p_list.append(fn + club)
        p_list.append(club + "2024")
        p_list.append(club + "2025")

    # 4. نمط الكلمات المفتاحية "الجزائرية"
    dz_keywords = ["dzair", "algerie", "bladi", "213", "momo"]
    for kw in dz_keywords:
        p_list.append(fn + kw)
        p_list.append(ln + kw)

    # 5. نمط "سنة الميلاد" المدمج
    current_year = 2026
    for year in range(1990, 2012):
        if len(p_list) > 15: break # تحديد العدد لضمان السرعة
        p_list.append(fn + str(year))

    # إضافة الباسووردات الثابتة التي لا يخلو منها أي صيد ناجح في الجزائر
    p_list.extend([
        "123456789", "1122334455", "00000000", 
        "algerie123", "dzair123", "123456dz"
    ])

    return list(set(p_list)) # إزالة التكرار لضمان كفاءة الفحص

